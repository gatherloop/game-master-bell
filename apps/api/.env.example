PORT=3000
HOST=0.0.0.0

# Path to the SQLite file backing the subscriptions store.
SUBSCRIPTIONS_DB_PATH=./data/subscriptions.db

# Comma-separated list of origins allowed to call this API via CORS (browser
# fetches from the bell web app / receiver PWA). Defaults to
# https://gatherloop.github.io, which covers all GitHub Pages sites under
# the gatherloop org (e.g. the game-master-bell-receiver PWA).
# CORS_ORIGINS=https://gatherloop.github.io,http://localhost:3001

# Shared secret staff enter in the receiver PWA to subscribe/unsubscribe a
# device. Required — POST/DELETE /subscriptions reject everything with 401
# if this is unset. Generate with e.g. `openssl rand -hex 16`.
STAFF_PASSCODE=

# VAPID key pair for Web Push. Generate a pair with `pnpm run vapid:generate`
# and paste both values here; never commit real keys. VAPID_PUBLIC_KEY is
# served publicly at GET /vapid-key. VAPID_PRIVATE_KEY signs outgoing push
# messages and must stay secret.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# VAPID contact per the spec: a `mailto:` address or `https:` URL push
# services may use to reach us about this key pair.
VAPID_SUBJECT=mailto:ops@gatherloop.id

# Path to the Firebase service-account JSON (Cloud Messaging scope) used to
# send FCM notifications to the native Android receiver. See
# docs/RUNBOOK.md "Creating the Firebase project + service account" for how
# to obtain this file. Required — the API refuses to start if this is unset
# or the file is missing/malformed (FR-A9). POST /call fans out to this
# topic alongside Web Push (PRD-v3 phase 5).
FCM_SERVICE_ACCOUNT_PATH=./fcm-service-account.json

# FCM topic every receiver app subscribes to. Defaults to "game-masters" —
# only override if you're running a separate Firebase project per environment.
# FCM_TOPIC=game-masters
