PORT=3000
HOST=0.0.0.0

# Comma-separated list of origins allowed to call this API via CORS (browser
# fetches from the bell web app). Defaults to https://gatherloop.github.io,
# which covers all GitHub Pages sites under the gatherloop org.
# CORS_ORIGINS=https://gatherloop.github.io,http://localhost:3001

# Path to the Firebase service-account JSON (Cloud Messaging scope) used to
# send FCM notifications to the native Android receiver. See
# docs/RUNBOOK.md "Creating the Firebase project + service account" for how
# to obtain this file. Required — the API refuses to start if this is unset
# or the file is missing/malformed (FR-A9).
FCM_SERVICE_ACCOUNT_PATH=./fcm-service-account.json

# FCM topic every receiver app subscribes to. Defaults to "game-masters" —
# only override if you're running a separate Firebase project per environment.
# FCM_TOPIC=game-masters
