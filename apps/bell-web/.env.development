# Local dev default: still points at the Firebase emulator (see
# `functions/package.json`'s `test:emulator` script for the matching
# --project/region) until the call API (game-master-bell-api) has a local
# dev server to point at instead. Override with a gitignored `.env.local`
# once you're running the call API locally.
VITE_CALL_API_URL=http://127.0.0.1:5001/demo-game-master-bell/us-central1/call
