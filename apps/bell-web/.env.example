# URL of the deployed call API's /call endpoint (see FR-W4).
# Copy this file to `.env.local` (gitignored) to override the committed
# `.env.development` default, or set it as a build-time env var in CI for
# production deploys (e.g. https://bell-api.gatherloop.id/call).
VITE_CALL_API_URL=http://127.0.0.1:5001/demo-game-master-bell/us-central1/call

# Cafe geofence (client-side, advisory — see src/lib/geofence.ts). When both
# latitude and longitude are set, the bell blocks a tap from a device that is
# confidently outside VITE_CAFE_RADIUS_METERS of this point; leave either blank
# to disable the check entirely. Coordinates are decimal degrees (e.g. copied
# from Google Maps: right-click the cafe → the "lat, lng" at the top).
# The check fails open — a denied permission prompt, missing GPS, timeout, or
# fuzzy fix all let the call through — so it deters casual off-site ringing
# without blocking real customers.
VITE_CAFE_LATITUDE=
VITE_CAFE_LONGITUDE=
# Allowed radius in metres (default 150 if unset). 150m absorbs indoor /
# upper-floor GPS error; tighten it only if false-positive off-site calls persist.
VITE_CAFE_RADIUS_METERS=150
