{
  "name": "@game-master-bell/functions",
  "private": true,
  "version": "0.0.0",
  "description": "Cloud Function: validates a bell call and sends the FCM push to game masters",
  "type": "module",
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "prebuild": "pnpm --filter @game-master-bell/shared build",
    "build": "tsc -b",
    "predev": "pnpm run build",
    "dev": "firebase emulators:start --only functions",
    "typecheck": "tsc -b",
    "test": "vitest run src",
    "pretest:emulator": "pnpm run build",
    "test:emulator": "firebase emulators:exec --project demo-game-master-bell --only functions \"vitest run test/emulator.test.ts\""
  },
  "dependencies": {
    "@game-master-bell/shared": "workspace:*",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.0",
    "@types/supertest": "^7.2.1",
    "express": "^4.22.2",
    "supertest": "^7.2.2",
    "vitest": "^4.1.10"
  }
}
